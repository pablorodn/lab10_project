# --- Proyecto Supabase separado: búsqueda de propiedades (solo lectura, opcional) ---
# Ver migrations/properties_db/. Ambas son opcionales: si faltan, la app arranca igual
# y la tool de búsqueda de propiedades queda deshabilitada mediante un error controlado
# (no tumba el servidor). Usar SIEMPRE la anon key de ese proyecto, nunca service role.
PROPERTIES_SUPABASE_URL=
PROPERTIES_SUPABASE_ANON_KEY=
# Solo usada por scripts/backfill_property_embeddings.py (proceso offline/manual o cron
# corrido por un humano, nunca por la app en el path de request de un usuario). NUNCA
# importar esta key desde app/tools o app/agent.
PROPERTIES_SUPABASE_SERVICE_ROLE_KEY=
